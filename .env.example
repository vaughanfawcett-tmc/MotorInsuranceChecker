# ----------------------------------------------------------------------------
# Business Insurance Checks - environment configuration
# Copy to .env and fill in. NEVER commit a real .env.
# ----------------------------------------------------------------------------

# Runtime mode: development | test | production
NODE_ENV=development

# Postgres connection string (all environments). Use a pooled URL on serverless.
# Vercel + Neon provide this automatically; locally, pull it with
# `vercel env pull .env.local` or run your own Postgres.
#   postgresql://user:password@host:5432/insurance_checks
DATABASE_URL="postgresql://user:password@host:5432/insurance_checks"

# Shared secret the intake caller must send as `Authorization: Bearer <secret>`.
# Generate one: `openssl rand -hex 32`. Min 16 chars.
INTAKE_SHARED_SECRET="replace-with-openssl-rand-hex-32"

# Reviewer dashboard password (single shared reviewer login for v1). Min 8 chars.
DASHBOARD_PASSWORD="replace-with-a-strong-password"

# Secret used to sign reviewer session cookies (HMAC). Min 16 chars.
# Generate one: `openssl rand -hex 32`.
SESSION_SECRET="replace-with-openssl-rand-hex-32"

# Secret used to sign driver upload links (HMAC). The portal that mints links
# must use the SAME value. Min 16 chars. Generate: `openssl rand -hex 32`.
UPLOAD_LINK_SECRET="replace-with-openssl-rand-hex-32"

# Extraction provider. Precedence: OpenAI, then Anthropic, then the MOCK
# extractor (dev/test only - it does not read real documents) if neither key
# is set. Set exactly one provider key in production.

# OpenAI key + vision-capable model (gpt-4o supports image and PDF input).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Anthropic key + vision-capable model (used only if OPENAI_API_KEY is empty).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Overall extraction confidence (0..1) below which a submission is routed to
# manual review instead of being auto-approved/rejected.
CONFIDENCE_THRESHOLD="0.7"
